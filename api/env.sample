AWS_ACCESS_KEY_ID=minio123
AWS_SECRET_ACCESS_KEY=minio123
# Tracking UI/API — must match credit_risk_forecast docker-compose mlflow service (mlflow[auth]).
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_TRACKING_USERNAME=admin
MLFLOW_TRACKING_PASSWORD=password1234
# Notebook on host/WSL: published MinIO S3 API (see credit_risk_forecast MINIO_API_HOST_PORT; default 19000).
# Inside Docker Compose use http://minio:9000 instead.
MLFLOW_S3_ENDPOINT_URL=http://127.0.0.1:19000
MLFLOW_BOTO_CLIENT_ADDRESSING_STYLE=path
MLFLOW_S3_IGNORE_TLS=true
AWS_DEFAULT_REGION=us-east-1

HF_TOKEN=your_huggingface_token_here
HF_REPO_ID=your-username/your-adapter-repo
# Hugging Face repo id for the LoRA adapter (langchain notebook)
ADAPTER_REPO=your-username/your-adapter-repo
HF_PRIVATE=false
# If huggingface.co fails DNS (e.g. getaddrinfo failed), try a mirror, then open a new terminal:
# HF_ENDPOINT=https://hf-mirror.com
BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
# Larger MoE (needs GPU + recent transformers + lots of RAM):
# BASE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# --- RAG (pgvector + documents/) ---
# Host-only API (python server.py on laptop): localhost:5433
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5433
# Docker Compose sets PGVECTOR_HOST=pgvector PGVECTOR_PORT=5432 automatically.
# PGVECTOR_USER=vector
# PGVECTOR_PASSWORD=vector
# PGVECTOR_DB=vectors
# RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_EMBEDDING_DIMENSION=384
# RAG_TOP_K=3
# Set true to chunk, embed, and index DOCUMENTS_DIR on API startup.
# RAG_AUTO_INGEST=false
# Drop PDFs/txt/md into DOCUMENTS_DIR, then:
#   POST /documents/uploads   (multipart)
#   POST /documents/ingest    (chunk + embed → pgvector)
# Full local stack (same as k8s): from repo root run `make local-up`

# --- Inference device (Docker + local-platform-up) ---
# Single switch — scripts/compose.sh sets TORCH_VARIANT and LLM_DEVICE for you.
# LLM_USE_GPU=false    # cpu (recommended on WSL without NVIDIA Container Toolkit)
# LLM_USE_GPU=true     # gpu (CUDA torch + nvidia device reservation)
# LLM_USE_GPU=auto       # gpu when `docker run --gpus all` works, else cpu
# LLM_GPU_COUNT=1      # GPUs per service when LLM_USE_GPU enables GPU mode

# --- Trino MCP (langchain notebook) — defaults to <workspace>/mcp next to llm/ ---
# TRINO_MCP_DIR=C:/Users/you/project/mcp
# TRINO_MCP_PYTHON=C:/Users/you/project/mcp/.venv/Scripts/python.exe
# Trino MCP — required for /trino/ask (local Jupyter on Windows uses SSE on localhost)
# TRINO_MCP_SSE_URL=http://127.0.0.1:8765/sse
# Docker Compose sets http://llm-trino-mcp:8765/sse automatically when unset

# --- Docker (llm/docker-compose.yml) ---
# LLM_API_PORT=8001
# AIRFLOW_DOCKER_NETWORK=credit_risk_forecast_default
# MCP_PORT=8765
# SKIP_PREFETCH=true
# TRINO_HOST=host.docker.internal
# TRINO_PORT=8080
# TRINO_USER=admin
# TRINO_PASSWORD=
# TRINO_HTTP_SCHEME=http

# --- Langfuse (main LangChain API: server.py /ask, /trino/ask) ---
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_MODEL_NAME=qween
# LANGFUSE_INPUT_PRICE_PER_UNIT=0.01
# LANGFUSE_OUTPUT_PRICE_PER_UNIT=0.01

# --- LangSmith (LangGraph API + Studio: server_langgraph.py, langgraph dev) ---
# Create a key at https://smith.langchain.com/settings
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=llm-langgraph
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=llm-langgraph
# Model name on LLM runs (for LangSmith cost if model pricing is configured in UI)
# LANGSMITH_MODEL_NAME=qween
# Optional per-token cost metadata on runs (LangSmith UI pricing is separate)
# LANGSMITH_INPUT_PRICE_PER_UNIT=0.000001
# LANGSMITH_OUTPUT_PRICE_PER_UNIT=0.000002
# Studio (local):  langgraph dev
# Studio (tunnel): langgraph dev --tunnel  → open the printed smith.langchain.com/studio URL

# --- Semantic cache (in-memory vector similarity, 24h TTL) ---
# SEMANTIC_CACHE_ENABLED=true
# Trino /trino/ask: caches full answer (SQL + result + summary). Unset = same as SEMANTIC_CACHE_ENABLED.
# Set false to always re-query Trino while still caching document /ask.
# SEMANTIC_CACHE_TRINO_ENABLED=false
# SEMANTIC_CACHE_TTL_SECONDS=86400
# SEMANTIC_CACHE_THRESHOLD=0.88
# SEMANTIC_CACHE_MAX_ENTRIES=2000
# SEMANTIC_CACHE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
